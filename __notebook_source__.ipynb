# Time-series forecasting requires proper datetime formatting.

# Converting the Date column into datetime datatype enables:
# - trend analysis
# - time indexing
# - rolling calculations
# - forecasting operations



df['Date'] = pd.to_datetime(
    
    df['Date']
)

print("Date Conversion Completed")


df = df.sort_values(
    
    by='Date'
)

df = df.reset_index(
    
    drop=True
)

print("Dataset Sorted Chronologically")


price_columns = [
    
    'Price',
    
    'Open',
    
    'High',
    
    'Low'
]

for col in price_columns:
    
    df[col] = df[col].str.replace(
        
        ',',
        
        ''
    )
    
    df[col] = df[col].astype(float)

print("Price Columns Cleaned Successfully")



df['Change %'] = df['Change %'].str.replace(
    
    '%',
    
    ''
)

df['Change %'] = df['Change %'].astype(float)

print("Change Percentage Column Cleaned")




def convert_volume(volume):
    
    if pd.isnull(volume):
        
        return np.nan
    
    volume = str(volume)
    
    if 'K' in volume:
        
        return float(
            
            volume.replace('K', '')
        ) * 1000
    
    elif 'M' in volume:
        
        return float(
            
            volume.replace('M', '')
        ) * 1000000
    
    else:
        
        try:
            
            return float(volume)
        
        except:
            
            return np.nan

df['Vol.'] = df['Vol.'].apply(
    
    convert_volume
)

print("Volume Column Cleaned Successfully")


df['Vol.'] = df['Vol.'].fillna(
    
    df['Vol.'].median()
)

print("Missing Values Handled Successfully")



df = df.drop_duplicates()

df = df.reset_index(
    
    drop=True
)

print("Duplicate Records Removed")



df.set_index(
    
    'Date',
    
    inplace=True
)

print("Date Column Set as Index")


df.info()


